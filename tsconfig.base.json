{
    "compilerOptions": {
        "target": "es2023",
        "jsx": "react-jsx",
        "module": "esnext",
        "moduleResolution": "bundler",
        "paths": {
            "@/*": ["./src/*"]
        },
        "types": ["chrome", "serviceworker", "react", "react-dom", "vite/client"],
        "strict": true,
        "noUncheckedIndexedAccess": true,
        "allowSyntheticDefaultImports": true,
        "esModuleInterop": true,
        "isolatedModules": true,
        "skipLibCheck": true
    }
}
