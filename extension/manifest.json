{
    "manifest_version": 3,

    "default_locale": "en",

    "name": "TikTok Downloader",
    "version": "1.0.0",
    "description": "A module for the Royal Downloader extension.",
    "icons": {
        "16": "assets/icons/icon-16.png",
        "32": "assets/icons/icon-32.png",
        "64": "assets/icons/icon-64.png",
        "128": "assets/icons/icon-128.png"
    },

    "background": {
        "service_worker": "build/background.js"
    },

    "action": {
        "default_popup": "popup.html",
        "default_icon": "assets/icons/icon-popup.png"
    },
    "options_ui": {
        "page": "options.html",
        "open_in_tab": true
    },

    "content_scripts": [
        {
            "matches": ["*://*.tiktok.com/*", "*://*.tiktokcdn.com/*"],
            "js": ["build/content-main-world.js"],
            "run_at": "document_start",
            "world": "MAIN"
        },
        {
            "matches": ["<all_urls>"],
            "js": ["build/content.js"],
            "run_at": "document_end"
        }
    ],

    "host_permissions": [
        "https://www.tiktok.com/*",
        "https://*.tiktok.com/*",
        "https://m.tiktok.com/*",
        "https://vm.tiktok.com/*",
        "https://*.tiktokcdn.com/*"
    ],

    "permissions": ["activeTab", "storage", "downloads", "declarativeNetRequest"],

    "declarative_net_request": {
        "rule_resources": [
            {
                "id": "tiktok_cdn_referer",
                "enabled": true,
                "path": "rules/tiktok-cdn-referer.json"
            }
        ]
    },

    "web_accessible_resources": [
        {
            "resources": ["assets/icons/icon-popup.png"],
            "matches": ["<all_urls>"]
        }
    ]
}
